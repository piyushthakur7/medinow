# Database URL from Railway PostgreSQL addon
DATABASE_URL=

# JWT Configuration - SET A STRONG SECRET!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server port (Railway sets this automatically via $PORT)
PORT=3001

# Expiry warning threshold (days before expiry to mark as "expiring soon")
EXPIRY_WARNING_DAYS=30

# Default low stock threshold
LOW_STOCK_THRESHOLD=10

# Frontend URL for CORS (set this to your Vercel/Railway web app URL)
FRONTEND_URL=
