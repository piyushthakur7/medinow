// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USERS
// ============================================================================

model User {
  id               String    @id @default(cuid())
  name             String
  email            String?   @unique
  phone            String?   @unique
  passwordHash     String
  planType         PlanType  @default(FREE)
  alertPreferences Json      @default("{\"expiry\": true, \"lowStock\": true, \"savings\": true}")
  lowStockThreshold Int      @default(10)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  medicines      Medicine[]
  alerts         Alert[]
  monthlySavings MonthlySavings[]

  @@index([email])
  @@index([phone])
}

// ============================================================================
// MEDICINES (Batch-Level)
// ============================================================================

model Medicine {
  id           String       @id @default(cuid())
  userId       String
  name         String
  expiryDate   DateTime
  unitPrice    Decimal?     @db.Decimal(10, 2)
  batchNumber  String?
  expiryStatus ExpiryStatus @default(SAFE)
  isDeleted    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements StockMovement[]
  alerts    Alert[]

  @@index([userId, isDeleted])
  @@index([expiryDate])
  @@index([name])
}

// ============================================================================
// STOCK MOVEMENTS (LEDGER - SOURCE OF TRUTH)
// ============================================================================

model StockMovement {
  id         String         @id @default(cuid())
  medicineId String
  type       MovementType
  quantity   Int
  reason     MovementReason
  notes      String?
  timestamp  DateTime       @default(now())

  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@index([medicineId, timestamp])
  @@index([timestamp])
}

// ============================================================================
// ALERTS
// ============================================================================

model Alert {
  id         String      @id @default(cuid())
  userId     String
  medicineId String?
  alertType  AlertType
  status     AlertStatus @default(PENDING)
  message    String?
  metadata   Json?
  createdAt  DateTime    @default(now())
  readAt     DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicine Medicine? @relation(fields: [medicineId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([medicineId])
}

// ============================================================================
// MONTHLY SAVINGS
// ============================================================================

model MonthlySavings {
  id               String   @id @default(cuid())
  userId           String
  monthYear        String   // Format: "2026-02"
  expirySavings    Decimal  @default(0) @db.Decimal(10, 2)
  overstockSavings Decimal  @default(0) @db.Decimal(10, 2)
  totalSavings     Decimal  @default(0) @db.Decimal(10, 2)
  medicinesSaved   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthYear])
  @@index([userId])
}

// ============================================================================
// MEDICINE MASTER (For autocomplete)
// ============================================================================

model MedicineMaster {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  manufacturer String?
  searchCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([name])
  @@index([searchCount])
}

// ============================================================================
// ENUMS
// ============================================================================

enum PlanType {
  FREE
  PRO
  BUSINESS
}

enum ExpiryStatus {
  SAFE
  EXPIRING_SOON
  EXPIRED
}

enum MovementType {
  IN
  OUT
}

enum MovementReason {
  ADDED
  SOLD
  MANUAL_ADJUSTMENT
  EXPIRED_REMOVAL
  RETURNED
}

enum AlertType {
  EXPIRY
  LOW_STOCK
  SAVINGS_SUMMARY
}

enum AlertStatus {
  PENDING
  SENT
  READ
}
